# Copy to .env and fill in. NEVER commit a real .env (see .gitignore).

# Weights & Biases (optional; only used when wandb.enabled=true in Hydra config)
WANDB_API_KEY=
WANDB_PROJECT=kgat

# Where datasets are downloaded / read from. Overrides the Hydra default paths.data_dir.
KGAT_DATA_DIR=./data

# Optional Neo4j backend (graph.neo4j_store adapter — stubbed this pass)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# HuggingFace token, if pulling gated dataset mirrors
HF_TOKEN=
